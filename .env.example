# Unison brain plugin — environment variables
# Copy this file to .env and fill in your values (never commit .env).

# Required: your Unison API key (get one at https://app.unisonlabs.ai or via /claude-unison:auth)
UNISON_TOKEN=usk_...

# Optional: override the API base URL (default: https://api.unisonlabs.ai)
# UNISON_API_URL=https://api.unisonlabs.ai

# Optional: enable verbose debug logging to stderr
# UNISON_DEBUG=true

# Optional: treat git worktrees as separate projects
# UNISON_ISOLATE_WORKTREES=true
